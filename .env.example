# PostgreSQL 数据库密码。Docker Compose 会用它创建数据库用户密码，生产环境必须换成强随机值。
POSTGRES_PASSWORD="replace-with-a-long-random-database-password"

# 应用主数据库连接串。本地直连宿主机数据库用 localhost；Docker 容器内会由 docker-compose.yml 自动覆盖为 postgres 服务地址。
DATABASE_URL="postgresql://auto_delivery:replace-with-a-long-random-database-password@localhost:5432/auto_delivery?schema=public"

# 测试数据库连接串。测试脚本会使用这个 schema 并自动执行迁移，避免清理开发库数据。
TEST_DATABASE_URL="postgresql://auto_delivery:replace-with-a-long-random-database-password@localhost:5432/auto_delivery?schema=test"

# 初始管理员用户名。首次启动容器或执行 npm run init:admin 时，如果没有管理员，会用这个用户名创建。
ADMIN_USERNAME="admin"

# 初始管理员密码，至少 12 位。生产环境必须换成强密码；已有管理员不会被重复覆盖。
ADMIN_PASSWORD="change-this-password"

# 敏感 token 查询哈希用的全局 pepper，至少 32 字符。修改后已有卡密、兑换凭证和会话相关 token 可能失效。
SECRET_PEPPER="replace-with-at-least-32-random-bytes"

# 管理后台登录 cookie 名称。多套系统部署在同一域名下时可改成不同名称。
SESSION_COOKIE_NAME="auto_delivery_admin"

# 对外访问地址。用于生成卡密交付文案里的兑换链接；生产环境应改成 https://你的域名。
# 如果没有反向代理、直接用端口访问，并且 APP_PORT 不是 3000，这里也要同步改成对应端口。
APP_BASE_URL="http://localhost:3000"

# Docker Compose 发布到宿主机的端口。如果服务器 3000 已被占用，改成 18080、8080 等空闲端口。
APP_PORT="3000"

# 本地文件存储目录。上传原文件、兑换 ZIP 和临时文件都会放在这个目录下。
STORAGE_ROOT="./storage"

# 管理后台文件上传请求体上限，对应 Next Server Actions bodySizeLimit。
ADMIN_UPLOAD_BODY_LIMIT="100mb"

# 运行环境。本地开发用 development；Docker Compose 会把应用容器覆盖为 production。
NODE_ENV="development"
