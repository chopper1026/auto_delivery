# PostgreSQL 数据库密码。生产环境必须换成强随机值。
POSTGRES_PASSWORD="replace-with-a-long-random-database-password"

# Go API 数据库连接串。本地开发直连宿主机数据库时使用 localhost；Docker Compose 会覆盖为 postgres 服务地址。
DATABASE_URL="postgresql://auto_delivery:replace-with-a-long-random-database-password@localhost:5432/auto_delivery?sslmode=disable"

# Redis 连接串。本地开发可使用 docker compose up -d redis。
REDIS_URL="redis://localhost:6379/0"

# 初始管理员。首次启动且数据库没有管理员时创建，之后不会覆盖已有管理员。
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# 敏感 token 查询哈希用的全局 pepper，至少 32 字符。修改后既有卡密、凭证和会话 token 会失效。
SECRET_PEPPER="replace-with-at-least-32-random-bytes"

# 管理后台登录 cookie 名称。
SESSION_COOKIE_NAME="auto_delivery_admin"

# 对外服务地址，用于生成卡密交付文案里的兑换链接。
APP_BASE_URL="http://localhost:3000"

# Docker Compose 发布到宿主机的端口。
APP_PORT="3000"

# Go 服务监听地址、本地文件存储、React 静态资源目录。
HTTP_ADDR=":3000"
STORAGE_ROOT="./storage"
STATIC_DIR="./frontend/dist"

# 时区。
TZ="Asia/Shanghai"
