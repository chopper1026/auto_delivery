# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.playwright-mcp
/playwright-report
/test-results

# local planning notes
/docs/superpowers/

# local agent config
/.claude/

# local worktrees
/.worktrees/

# local GitNexus index
/.gitnexus/

# production
/build
/frontend/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local storage
/data
/storage
/backend/storage/
/storage-test

# typescript
*.tsbuildinfo
